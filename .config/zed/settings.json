// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",

  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "favorite_config_option_values": {
        "model": ["claude-opus-4.7", "gpt-5.5"],
      },
      "default_config_options": {
        "model": "claude-opus-4.7",
        "allow_all": "on",
      },
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },

  "project_panel": {
    "dock": "right",
  },

  "outline_panel": {
    "dock": "right",
  },

  "collaboration_panel": {
    "dock": "right",
  },

  "agent": {
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "favorite_models": [],
    "model_parameters": [],
  },

  "git_panel": {
    "dock": "right",
  },

  "diff_view_style": "unified",
  "format_on_save": "off",

  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },

  "icon_theme": {
    "mode": "system",
    "light": "JetBrains New UI Icons (Light)",
    "dark": "JetBrains New UI Icons (Dark)",
  },

  "terminal": {
    "font_size": 13.0,
    "font_family": "Maple Mono NF",
  },

  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.setting",
    "**/*.tfstate",
    "**/__pycache__",
    "**/.ruff_cache",
    "**/.mypy_cache",
  ],

  "session": {
    "trust_all_worktrees": true,
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
