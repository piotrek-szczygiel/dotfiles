window-width = 130
window-height = 40
window-padding-x = 10
window-padding-y = 10
window-colorspace = display-p3

theme = dark:Ayu,light:Ayu Light

font-family = "Maple Mono NF"
font-size = 12

font-thicken = false
adjust-cursor-thickness = 4

confirm-close-surface = false

working-directory = /home/piotr/Developer
