{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",

      "sudo*": "deny",

      "./mvnw *": "allow",

      "basename*": "allow",
      "bun*": "allow",
      "cat*": "allow",
      "dirname*": "allow",
      "file*": "allow",
      "grep*": "allow",
      "make*": "allow",
      "head*": "allow",
      "ls*": "allow",
      "mkdir*": "allow",
      "nohup*": "allow",
      "pgrep*": "allow",
      "pwd*": "allow",
      "ps*": "allow",
      "jar*": "allow",
      "javap*": "allow",
      "jq*": "allow",
      "realpath*": "allow",
      "rg*": "allow",
      "sleep*": "allow",
      "sort*": "allow",
      "ss*": "allow",
      "stat*": "allow",
      "tail*": "allow",
      "uv*": "allow",
      "wc*": "allow",
      "which*": "allow",

      "git add*": "allow",
      "git commit*": "allow",
      "git branch --all*": "allow",
      "git branch --show-current*": "allow",
      "git diff*": "allow",
      "git fetch*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git remote -v*": "allow",
      "git rev-parse*": "allow",

      "gh api repos*": "allow",
      "gh auth status*": "allow",
      "gh repo view*": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh pr status*": "allow",
      "gh pr checks*": "allow",
      "gh pr diff*": "allow",
      "gh issue list*": "allow",
      "gh issue view*": "allow",
      "gh issue status*": "allow",
      "gh search prs*": "allow",
      "gh search issues*": "allow",
      "gh search repos*": "allow"
    },
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://192.168.100.125:11434/v1"
      },
      "models": {
        "glm-4.7-flash:32k": {
          "name": "GLM 4.7 Flash 32k"
        }
      }
    }
  }
}
