#!/bin/sh
set -eu

command -v pactl >/dev/null 2>&1 || exit 1
command -v jq >/dev/null 2>&1 || exit 1

sinks_json=$(pactl -f json list sinks)
sink_count=$(printf '%s\n' "$sinks_json" | jq 'length')

[ "$sink_count" -gt 1 ] || exit 0

default_sink=$(pactl get-default-sink 2>/dev/null || true)

next_sink=$(
    printf '%s\n' "$sinks_json" |
        jq -r --arg current "$default_sink" '
            [.[].name] as $names
            | ($names | index($current)) as $idx
            | if $idx == null then $names[0]
              else $names[(($idx + 1) % ($names | length))]
              end
        '
)

[ -n "$next_sink" ] && [ "$next_sink" != "null" ] || exit 1

pactl set-default-sink "$next_sink"

pactl -f json list sink-inputs |
    jq -r '.[].index' |
    while IFS= read -r input; do
        [ -n "$input" ] && pactl move-sink-input "$input" "$next_sink" >/dev/null 2>&1 || true
    done

description=$(
    printf '%s\n' "$sinks_json" |
        jq -r --arg sink "$next_sink" '.[] | select(.name == $sink) | .description'
)

if command -v notify-send >/dev/null 2>&1; then
    notify-send -a "Audio" "Output switched" "$description"
fi
